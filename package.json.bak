{
  "name": "@vos/learn",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./views/Learn": "./src/views/Learn/index.jsx",
    "./lib/muscleMapping": "./src/lib/muscleMapping.js",
    "./lib/firebase": "./src/lib/firebase.js"
  },
  "scripts": {
    "dev": "vite --config vite.config.js",
    "build": "vite build --config vite.config.js",
    "build:firebase": "vite build --mode firebase --config vite.config.js",
    "deploy": "npm run build:firebase && firebase deploy --only hosting --project fitness-aos",
    "preview": "vite preview --config vite.config.js"
  },
  "dependencies": {
    "body-muscles": "^1.0.0",
    "firebase": "^11.0.1",
    "lucide-react": "^0.451.0",
    "react": ">=18",
    "react-body-highlighter": "^2.0.5",
    "react-dom": ">=18",
    "react-muscle-highlighter": "^1.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
